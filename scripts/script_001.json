    "data_size": 136,
    "nom_orig": "Lisa",
    "texte_orig": "Knew[SP]it...[1205][001E][SP]But[SP]do[SP]you[SP]know[SP]how[SP]to\nget[SP]to[SP]Sumaru[SP]Prison?",
