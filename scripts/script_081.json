  {
    "id": 6,
    "offset": 112898,
    "slot_size": 174,
    "data_size": 170,
    "nom_orig": "Maya",
    "texte_orig": "I[SP]can[SP]feel[SP]it[SP]again...[SP]King[SP]Leo's[SP]hatred\nand[SP]insanity[SP]is[SP]getting[SP]closer...",
