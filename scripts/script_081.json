  {
    "id": 3,
    "offset": 112198,
    "slot_size": 164,
    "data_size": 160,
    "nom_orig": "Maya",
    "texte_orig": "King[SP]Leo!?[SP]So[SP]he's[SP]alive...[1205][001E][SP]The[SP]kids[SP]are[SP]in\ndanger![SP]Let's[SP]go,[SP]guys!",
