  {
    "id": 4,
    "offset": 112362,
    "slot_size": 270,
    "data_size": 266,
    "nom_orig": "Ginko",
    "texte_orig": "Geez,[SP]talk[SP]about[SP]bad[SP]timing![SP]There's[SP]no[SP]way\nI'm[SP]gonna[SP]let[SP]him[SP]kill[SP]me[SP]here![SP]Let's[SP]beat\nhim[SP]up[SP]quick[SP]and[SP]make[SP]our[SP]getaway!",
